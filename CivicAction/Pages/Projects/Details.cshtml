@page
@model CivicAction.Pages.Projects.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Project</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.Title)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.Description)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.Hours)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.Hours)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.Organization)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.Organization)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.Start)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.Start)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.End)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.End)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.IsApproved)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.IsApproved)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.IsWorkshop)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.IsWorkshop)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.Student)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.Student.FirstMidName) @Html.DisplayFor(model => model.Project.Student.LastName)
        </dd>
    </dl>
</div>

<div>
    <a asp-page="./Edit" asp-route-id="@Model.Project.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>

<hr />

<h4>Hours Logged</h4>
<div class="row">
    <div class="col-md-8">
        @if (Model.Updates.Count == 0)
        {
            <p>No hours logged yet.</p>
        }
        else
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th>Hours Done</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var update in Model.Updates)
                    {
                        <tr>
                            <td>@update.Description</td>
                            <td>@update.HoursDone</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<hr />

<h4>Log New Hours</h4>
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="NewUpdate.Description" class="control-label"></label>
                <textarea asp-for="NewUpdate.Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="NewUpdate.Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NewUpdate.HoursDone" class="control-label"></label>
                <input asp-for="NewUpdate.HoursDone" class="form-control" type="number" step="0.5" />
                <span asp-validation-for="NewUpdate.HoursDone" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Log Hours" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
