@page
@model CivicAction.Pages.Projects.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Project</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <div asp-validation-summary="All" class="text-danger"></div>
        
        <form method="post">
            <input type="hidden" asp-for="Project.Id" />
            <div class="form-group">
                <label asp-for="Project.Description" class="control-label"></label>
                <input asp-for="Project.Description" class="form-control" />
                <span asp-validation-for="Project.Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Project.Hours" class="control-label"></label>
                <input asp-for="Project.Hours" class="form-control" />
                <span asp-validation-for="Project.Hours" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Project.Organization" class="control-label"></label>
                <input asp-for="Project.Organization" class="form-control" />
                <span asp-validation-for="Project.Organization" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Project.Start" class="control-label"></label>
                <input asp-for="Project.Start" class="form-control" type="date" />
                <span asp-validation-for="Project.Start" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Project.End" class="control-label"></label>
                <input asp-for="Project.End" class="form-control" type="date" />
                <span asp-validation-for="Project.End" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Project.StudentID" class="control-label"></label>
                <select asp-for="Project.StudentID" class="form-control" asp-items="ViewBag.StudentID">
                    <option value="">-- Select a Student --</option>
                </select>
                <span asp-validation-for="Project.StudentID" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Project.IsApproved" />
                    @Html.DisplayNameFor(model => model.Project.IsApproved)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
